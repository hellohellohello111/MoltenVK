-	if (padded_output || padded_input)
+	// If the output type was overridden due to a format mismatch, DON'T write to
+	// this output at all. In MSL, if a fragment shader doesn't write to a [[color(N)]]
+	// output, the attachment retains its previous value. This preserves data written
+	// by correctly-typed shaders (e.g. the prepass writes uint4 to RGBA16Uint, then
+	// a float4 ForwardPBR shader skips writing → prepass data preserved).
+	// On Android, the float→uint truncation produces ~0, but the prepass data is
+	// typically preserved through depth testing. Skipping the write achieves the same result.
+	if (needs_output_type_cast)
+	{
+		entry_func.add_local_variable(var.self);
+		vars_needing_early_declaration.push_back(var.self);
+
+		// Don't add a fixup hook — the output struct member won't be written.
+		// The shader's original value is computed but discarded for this attachment.
+
+		auto &entry_func_ref = get<SPIRFunction>(ir.default_entry_point);
+		ir.meta[var.self].decoration.alias = to_name(var.self);
+	}
