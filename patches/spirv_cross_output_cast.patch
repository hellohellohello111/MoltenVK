+	// Check if the fragment output type needs to be overridden to match the render target format.
+	// On Metal, shader output type must exactly match the color attachment pixel format.
+	// Android Vulkan drivers handle mismatches implicitly (e.g. float4 → RGBA16Uint truncates to ~0).
+	// This override makes SPIRV-Cross generate the correct output type and insert a cast.
+	bool needs_output_type_cast = false;
+	uint32_t original_type_id = type_id;
+	if (storage == StorageClassOutput && !is_builtin &&
+	    get_entry_point().model == ExecutionModelFragment &&
+	    has_decoration(var.self, DecorationLocation))
+	{
+		uint32_t locn = get_decoration(var.self, DecorationLocation);
+		auto output_itr = outputs_by_location.find({locn, 0});
+		if (output_itr != end(outputs_by_location))
+		{
+			auto &output = output_itr->second;
+			auto &current_type = get<SPIRType>(type_id);
+
+			// If shader outputs float but render target expects uint, override to uint
+			bool shader_is_float = (current_type.basetype == SPIRType::Float ||
+			                        current_type.basetype == SPIRType::Half);
+			bool target_is_uint = (output.format == MSL_SHADER_VARIABLE_FORMAT_UINT8 ||
+			                       output.format == MSL_SHADER_VARIABLE_FORMAT_UINT16);
+
+			if (shader_is_float && target_is_uint)
+			{
+				// Build a uint type matching the shader's vecsize
+				uint32_t new_type_id = ir.increase_bound_by(1);
+				SPIRType new_type = current_type;
+				if (output.format == MSL_SHADER_VARIABLE_FORMAT_UINT16)
+				{
+					new_type.basetype = SPIRType::UShort;
+					new_type.width = 16;
+				}
+				else
+				{
+					new_type.basetype = SPIRType::UInt;
+					new_type.width = 32;
+				}
+				set<SPIRType>(new_type_id, new_type);
+				type_id = new_type_id;
+				needs_output_type_cast = true;
+			}
+
+			// If shader outputs uint but render target expects float, override to float
+			bool shader_is_uint = (current_type.basetype == SPIRType::UInt ||
+			                       current_type.basetype == SPIRType::UShort);
+			bool target_is_float = (output.format == MSL_SHADER_VARIABLE_FORMAT_ANY16 ||
+			                        output.format == MSL_SHADER_VARIABLE_FORMAT_ANY32 ||
+			                        output.format == MSL_SHADER_VARIABLE_FORMAT_OTHER);
+
+			if (shader_is_uint && target_is_float)
+			{
+				uint32_t new_type_id = ir.increase_bound_by(1);
+				SPIRType new_type = current_type;
+				if (output.format == MSL_SHADER_VARIABLE_FORMAT_ANY16)
+				{
+					new_type.basetype = SPIRType::Half;
+					new_type.width = 16;
+				}
+				else
+				{
+					new_type.basetype = SPIRType::Float;
+					new_type.width = 32;
+				}
+				set<SPIRType>(new_type_id, new_type);
+				type_id = new_type_id;
+				needs_output_type_cast = true;
+			}
+		}
+	}
+
 	if (storage == StorageClassInput && pull_model_inputs.count(var.self))
 		ib_type.member_types.push_back(build_msl_interpolant_type(type_id, is_noperspective));
